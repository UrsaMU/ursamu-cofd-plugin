{
  "key": "chargen-mortal",
  "title": "+cg — guided Mortal character generation",
  "description": "Full guided chargen walkthrough for a Mortal template: start, set concept/template, distribute attributes, skills, merits, and submit.",
  "vars": { "player": "Novice" },
  "steps": [
    { "sub": "Starting Character Generation" },
    { "note": "+cg with no prior state opens a fresh character generation session and shows Stage 1 instructions." },
    { "cmd": "+cg", "label": "start chargen" },
    { "expect": "Stage" },

    { "sub": "Stage 1 — Concept & Template" },
    { "note": "Set your character concept and template before moving on." },
    { "cmd": "+cg/set concept=Burned-out nurse seeking redemption", "label": "set concept" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set template=mortal", "label": "set template to Mortal" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set virtue=Justice", "label": "set Virtue" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set vice=Sloth", "label": "set Vice" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next", "label": "advance to Stage 2" },
    { "expect": "Stage" },

    { "sub": "Stage 2 — Attributes (5/4/3 priority)" },
    { "note": "Distribute 5+4+3 dots across the three attribute categories. At least 1 per attribute is free." },
    { "cmd": "+cg/set strength=2",      "label": "Physical priority" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set dexterity=3" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set stamina=3" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set intelligence=2",  "label": "Mental secondary" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set wits=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set resolve=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set presence=2",      "label": "Social tertiary" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set manipulation=1" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set composure=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next", "label": "advance to Stage 3" },
    { "expect": "Stage" },

    { "sub": "Stage 3 — Skills (11/7/4 priority)" },
    { "cmd": "+cg/set medicine=3",       "label": "Physical-group skills (tertiary)" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set athletics=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set drive=1" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set academics=3",      "label": "Mental-group skills (primary)" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set investigation=3" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set computer=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set science=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set empathy=3",        "label": "Social-group skills (secondary)" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set persuasion=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set subterfuge=2" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next", "label": "advance to Stage 4" },
    { "expect": "Stage" },

    { "sub": "Stage 4 — Merits (7 dots)" },
    { "note": "Spend up to 7 merit dots. Each merit must exist in resources/merits.json and prerequisites must be met." },
    { "cmd": "+cg/set contacts=2",       "label": "Contacts ••" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set resources=2",      "label": "Resources ••" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set trained observer=1", "label": "Trained Observer •" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set holistic awareness=1", "label": "Holistic Awareness •" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next", "label": "advance to Stage 5" },
    { "expect": "Stage" },

    { "sub": "Stage 5 — Specialties & Finishing Touches" },
    { "cmd": "+cg/set specialty/investigation=Crime Scenes", "label": "add specialty" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set specialty/medicine=Emergency Care" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next", "label": "advance to Stage 6 (Review)" },
    { "expect": "Stage" },

    { "sub": "Stage 6 — Review & Submit" },
    { "note": "+cg with no switch shows the current stage summary. Submit finalises and approves the sheet." },
    { "cmd": "+cg",         "label": "review current state" },
    { "expect": "Stage" },
    { "cmd": "+cg/submit",  "label": "approve and lock in the sheet" },
    { "expect": "complete" }
  ]
}
