{
  "key": "combat-autofire",
  "title": "+attack autofire -- burst modes and reload",
  "description": "Demonstrates short burst (+1 pool, one target), medium burst (+2 pool, up to three targets), and reloading. One player with a pistol and SMG, two targets.",
  "vars": { "player": "Jax" },
  "setup": {
    "targets": {
      "Jax": {
        "flags": ["player", "connected"],
        "state": {
          "cofd": {
            "attributes": {
              "strength": 2,
              "dexterity": 3,
              "stamina": 2,
              "intelligence": 2,
              "wits": 2,
              "resolve": 2,
              "presence": 2,
              "manipulation": 2,
              "composure": 2
            },
            "skills": {
              "firearms": 3,
              "athletics": 2
            },
            "health": { "max": 7, "bashing": 0, "lethal": 0, "aggravated": 0 },
            "willpower": { "max": 4, "current": 4 },
            "gear": {
              "smg": {
                "name": "SMG",
                "type": "ranged",
                "size": 2,
                "damage": 2,
                "initiative": -3,
                "range": { "short": 20, "medium": 40, "long": 80 },
                "capacity": 30,
                "ammo": 30,
                "autofire": true
              }
            }
          }
        }
      },
      "Marcus": {
        "flags": ["player", "connected"],
        "state": {
          "cofd": {
            "attributes": {
              "strength": 2,
              "dexterity": 2,
              "stamina": 2,
              "intelligence": 2,
              "wits": 2,
              "resolve": 2,
              "presence": 2,
              "manipulation": 2,
              "composure": 2
            },
            "skills": { "brawl": 2 },
            "health": { "max": 7, "bashing": 0, "lethal": 0, "aggravated": 0 },
            "willpower": { "max": 4, "current": 4 }
          }
        }
      },
      "Cass": {
        "flags": ["player", "connected"],
        "state": {
          "cofd": {
            "attributes": {
              "strength": 2,
              "dexterity": 2,
              "stamina": 2,
              "intelligence": 2,
              "wits": 2,
              "resolve": 2,
              "presence": 2,
              "manipulation": 2,
              "composure": 2
            },
            "skills": { "brawl": 2 },
            "health": { "max": 7, "bashing": 0, "lethal": 0, "aggravated": 0 },
            "willpower": { "max": 4, "current": 4 }
          }
        }
      }
    }
  },
  "steps": [
    { "sub": "Setup: Open and Join" },
    { "cmd": "+combat/start", "as": "admin", "label": "open encounter" },
    { "expect": "encounter" },
    { "cmd": "+combat/join", "label": "Jax joins" },
    { "expect": "joined" },
    { "cmd": "+combat/join", "as": "Marcus", "label": "Marcus joins" },
    { "expect": "joined" },
    { "cmd": "+combat/join", "as": "Cass", "label": "Cass joins" },
    { "expect": "joined" },
    { "cmd": "+combat/begin", "as": "admin", "label": "roll initiative" },
    { "expect": "initiative" },
    { "cmd": "+combat/order", "label": "review turn order" },
    { "expect": "Jax" },

    { "sub": "Short Burst -- One Target" },
    { "note": "Short burst: +1 to pool, 3 rounds expended. Dexterity 3 + Firearms 3 + 1 = 7 dice. Defense does not apply to ranged." },
    { "cmd": "+attack/burst-short Marcus", "label": "Jax fires short burst at Marcus" },
    { "expect": "burst" },
    { "cmd": "+combat/next", "as": "admin", "label": "advance turn" },
    { "expect": "turn" },
    { "cmd": "+combat/next", "as": "admin", "label": "skip Marcus" },
    { "expect": "turn" },
    { "cmd": "+combat/next", "as": "admin", "label": "skip Cass; round 2" },
    { "expect": "round" },

    { "sub": "Medium Burst -- Two Targets" },
    { "note": "Medium burst: +2 pool, 10 rounds expended, up to 3 targets. With 2 targets: -1 per extra target, so net +1. One roll per target." },
    { "cmd": "+attack/burst-med Marcus=Cass", "label": "Jax fires medium burst at Marcus and Cass" },
    { "expect": "burst" },
    { "cmd": "+combat/next", "as": "admin", "label": "advance turn" },
    { "expect": "turn" },
    { "cmd": "+combat/next", "as": "admin", "label": "skip Marcus" },
    { "expect": "turn" },
    { "cmd": "+combat/next", "as": "admin", "label": "skip Cass; round 3" },
    { "expect": "round" },

    { "sub": "Reload" },
    { "note": "SMG is loaded with a magazine; reloading does not cost Defense." },
    { "cmd": "+reload", "label": "Jax reloads SMG" },
    { "expect": "reloaded" },
    { "cmd": "+combat/next", "as": "admin", "label": "advance turn" },
    { "expect": "turn" },

    { "sub": "Close the Encounter" },
    { "cmd": "+combat/end", "as": "admin", "label": "end fight" },
    { "expect": "ended" },

    { "reset": true }
  ]
}
