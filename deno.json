{
  "name": "@ursamu/cofd-plugin",
  "version": "1.0.0",
  "description": "Chronicles of Darkness 2e plugin for UrsaMU — character sheets, guided chargen, and d10 dice with 10/9/8-again, rote, and Willpower spend.",
  "exports": "./index.ts",
  "tasks": {
    "test": "deno test -A --unstable-kv",
    "showcase": "deno run -A --unstable-kv --import-map=showcase.importmap.json tools/showcase.ts"
  },
  "exclude": [".claude/", "data/"],
  "publish": {
    "include": [
      "src",
      "help",
      "resources",
      "templates",
      "index.ts",
      "commands.ts",
      "cofd.ts",
      "cg.ts",
      "templates.ts",
      "routes.ts",
      "deno.json",
      "ursamu.plugin.json",
      "README.md"
    ],
    "exclude": ["tests", "tools", "showcases", "docs"]
  },
  "imports": {
    "ursamu": "jsr:@ursamu/ursamu@^2.6",
    "@ursamu/ursamu": "jsr:@ursamu/ursamu@^2.6",
    "@ursamu/help-plugin": "https://raw.githubusercontent.com/UrsaMU/help-plugin/v1.0.2/mod.ts",
    "@ursamu/jobs-plugin": "https://raw.githubusercontent.com/UrsaMU/jobs-plugin/v1.4.1/mod.ts",
    "@ursamu/mail-plugin": "https://raw.githubusercontent.com/UrsaMU/mail-plugin/v2.3.1/index.ts",
    "@ursamu/mushcode": "jsr:@ursamu/mushcode",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "@std/testing/bdd": "jsr:@std/testing@^0.224.0/bdd",
    "@std/path": "jsr:@std/path@^0.224.0",
    "@std/fs": "jsr:@std/fs@^0.224.0",
    "@std/flags": "jsr:@std/flags@^0.224.0"
  }
}
